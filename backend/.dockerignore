# Keep the build context small and the image clean. The model artifact
# (app/model/cloud_detector.onnx) and alembic/ are deliberately NOT ignored —
# they ship in the image.
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Tests + local scripts are not needed at runtime.
tests/
scripts/

# Local env / secrets must never enter the image.
.env
.env.*

# Tooling / VCS noise.
.git/
.gitignore
.dockerignore
Dockerfile
fly.toml
# README.md is referenced by pyproject.toml (readme = ...), so it must stay in the
# context for `pip install .`; ignore other markdown only.
*.md
!README.md
